	<Attributes>
		<Attribute name="List" id="1">
			<Type>
				<v8:Type>cfg:DynamicList</v8:Type>
			</Type>
			<MainAttribute>true</MainAttribute>
			<Settings xsi:type="DynamicList">
				<ManualQuery>true</ManualQuery>
				<DynamicDataRead>true</DynamicDataRead>
				<QueryText>SELECT
	AccessRightsDependencies.SubordinateTable,
	AccessRightsDependencies.LeadingTableType,
	MetadataObjectIDs.Ref AS LeadingTable,
	TRUE AS CheckReadInsteadOfChange
FROM
	InformationRegister.AccessRightsDependencies AS AccessRightsDependencies
		LEFT JOIN Catalog.MetadataObjectIDs AS MetadataObjectIDs
		ON AccessRightsDependencies.LeadingTableType = MetadataObjectIDs.EmptyRefValue</QueryText>
				<MainTable>InformationRegister.AccessRightsDependencies</MainTable>
				<ListSettings>
					<dcsset:filter>
						<dcsset:viewMode>Normal</dcsset:viewMode>
						<dcsset:userSettingID>dfcece9d-5077-440b-b6b3-45a5cb4538eb</dcsset:userSettingID>
