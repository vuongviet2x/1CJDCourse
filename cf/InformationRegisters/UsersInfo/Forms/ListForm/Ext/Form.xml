	<Attributes>
		<Attribute name="List" id="1">
			<Type>
				<v8:Type>cfg:DynamicList</v8:Type>
			</Type>
			<MainAttribute>true</MainAttribute>
			<Settings xsi:type="DynamicList">
				<ManualQuery>true</ManualQuery>
				<DynamicDataRead>true</DynamicDataRead>
				<QueryText>SELECT
	InformationRecords.NumberOfStatePicture - 1 AS PictureNumber,
	InformationRecords.User AS User,
	InformationRecords.UserMustChangePasswordOnAuthorization AS UserMustChangePasswordOnAuthorization,
	InformationRecords.UnlimitedValidityPeriod AS UnlimitedValidityPeriod,
	InformationRecords.ValidityPeriod AS ValidityPeriod,
	InformationRecords.InactivityPeriodBeforeDenyingAuthorization AS InactivityPeriodBeforeDenyingAuthorization,
	InformationRecords.AuthorizationAllowedDate AS AuthorizationAllowedDate,
	InformationRecords.LastActivityDate AS LastActivityDate,
	InformationRecords.AutomaticAuthorizationProhibitionDate AS AutomaticAuthorizationProhibitionDate,
	InformationRecords.DeletePasswordUsageStartDate AS DeletePasswordUsageStartDate,
	InformationRecords.LastUsedClient AS LastUsedClient,
	InformationRecords.NumberOfStatePicture AS NumberOfStatePicture,
	InformationRecords.CanSignIn AS CanSignIn,
	InformationRecords.IsAppLogonRestricted AS IsAppLogonRestricted,
	InformationRecords.HasNoRights AS HasNoRights,
	InformationRecords.HasInsufficientRightForLogon AS HasInsufficientRightForLogon,
	InformationRecords.Name AS Name,
	InformationRecords.Email AS Email,
	InformationRecords.StandardAuthentication AS StandardAuthentication,
	InformationRecords.CannotChangePassword AS CannotChangePassword,
	InformationRecords.CannotRecoveryPassword AS CannotRecoveryPassword,
	InformationRecords.ShowInList AS ShowInList,
	InformationRecords.OpenIDAuthentication AS OpenIDAuthentication,
	InformationRecords.OpenIDConnectAuthentication AS OpenIDConnectAuthentication,
	InformationRecords.AccessTokenAuthentication AS AccessTokenAuthentication,
	InformationRecords.OSAuthentication AS OSAuthentication,
	InformationRecords.OSUser AS OSUser,
	InformationRecords.Language AS Language,
	InformationRecords.UnsafeActionProtection AS UnsafeActionProtection
FROM
	InformationRegister.UsersInfo AS InformationRecords</QueryText>
				<MainTable>InformationRegister.UsersInfo</MainTable>
