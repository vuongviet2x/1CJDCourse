    <main>true</main>
    <extInfo xsi:type="form:DynamicListExtInfo">
      <queryText>SELECT
	GoodsInWarehousesBalance.Batch AS Batch,
	GoodsInWarehousesBalance.QuantityBalance AS Quantity
FROM
	AccumulationRegister.GoodsInWarehouses.Balance(
			&amp;Date,
			Product = &amp;Product
				AND Warehouse = &amp;Warehouse) AS GoodsInWarehousesBalance</queryText>
      <autoFillAvailableFields>true</autoFillAvailableFields>
      <customQuery>true</customQuery>
      <autoSaveUserSettings>true</autoSaveUserSettings>
      <getInvisibleFieldPresentations>true</getInvisibleFieldPresentations>
      <fields xsi:type="schema:DataCompositionSchemaDataSetField">
        <dataPath>Warehouse</dataPath>
        <field>Warehouse</field>
      </fields>
      <fields xsi:type="schema:DataCompositionSchemaDataSetField">
